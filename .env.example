# Copy to your Railway service variables (or a local .env). Do NOT commit real secrets.

# Generate one with:  python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# Must be False in production.
DJANGO_DEBUG=False

# Optional: extra hosts/origins (comma-separated). Railway's own domain is allowed automatically.
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com

# Optional: set to a Postgres URL to use a managed database instead of SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
